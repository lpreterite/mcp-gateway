{
  "name": "mcp-gateway",
  "version": "1.0.0",
  "description": "MCP Gateway - Centralized MCP server management with connection pooling and HTTP/SSE transport",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-gateway": "./dist/gateway/index.js",
    "mcp-gateway-bridge": "./dist/stdio-bridge/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/gateway/index.js",
    "dev": "tsx src/gateway/index.ts",
    "gateway": "tsx src/gateway/index.ts",
    "dev:bridge": "tsx src/stdio-bridge/index.ts",
    "test": "npm run test:bridge && npm run test:types",
    "test:bridge": "tsx src/test/bridge-test.ts",
    "test:types": "tsx src/test/stdio-types-test.ts",
    "test:pool": "tsx src/test/pool-test.ts"
  },
  "keywords": ["mcp", "opencode", "gateway", "sse"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
